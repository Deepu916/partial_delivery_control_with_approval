<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="res_config_settings_form_view" model="ir.ui.view">
        <field name="name">res_config_settings_form_view</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="stock.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//setting[@id='reception_report']" position="after">
                   <setting string="Partial Delivery Approval Users" help="Select users for partial delivery approval">
                       <field name="partial_delivery_approval_user_ids" widget="many2many_tags"/>
                   </setting>
            </xpath>
        </field>
    </record>
</odoo>