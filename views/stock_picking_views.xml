<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="stock_picking_form_view" model="ir.ui.view">
        <field name="name">stock.picking.form.view</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//button[@name='action_confirm']" position="attributes">
                <attribute name="invisible">state != 'draft'</attribute>
            </xpath>
            <xpath expr="//button[@name='button_validate']" position="attributes">
                <attribute name="invisible">state in ['approval','done','draft']</attribute>
            </xpath>
            <xpath expr="//button[@name='button_validate']" position="after">
                <button name="action_approved"
                        string="Approved"
                        class="btn-primary"
                        type="object"
                        invisible="(uid not in user_ids) or (state != 'approval')"/>
            </xpath>
        </field>
    </record>
</odoo>